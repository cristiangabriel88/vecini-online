# vecini.online - DEMO (frontend-only offline mode).
#
# This stage runs with no backend at all: no Supabase, no Resend, no Telegram.
# The app runs entirely in the browser using the seeded Romanian demo data.
# Use it for design iteration, screenshotting, and UI review without any
# external setup. Copy to .env.demo (never commit the actual file).
#
# To run: cp .env.demo.example .env.demo && npm run dev:demo   (T172 lands dev:demo)

# No Supabase credentials -- the app auto-detects their absence and enters demo mode.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Deployment stage: demo.
VITE_APP_STAGE=demo

# Default locale (ro or en)
VITE_DEFAULT_LOCALE=ro

# No 2FA enforcement in demo mode.
VITE_SECURITY_ENFORCEMENT=relaxed
