    "date-fns": "^4.1.0",
    "dompurify": "^3.4.5",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^15.2.0",
