# vecini.online environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# ============================================================
# Supabase
# ============================================================
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
# When both VITE_ vars are present the app uses real Supabase Auth (email +
# password sign-up/login, email verification, password reset). When either is
# absent it falls back to the offline demo mode.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Auth dashboard configuration (Authentication > Providers > Email):
#  - Enable the Email provider. For the invite-driven onboarding flow, turn
#    "Confirm email" OFF: the single-use, 24h, opaque invite link is itself the
#    proof of email ownership, so the user goes invite -> set password -> in,
#    without a second confirmation email. (See RUNBOOK-MVP.md / DECISIONS.md.)
#  - Set Site URL to VITE_APP_URL (the resident/admin origin) below, and add
#    "<VITE_APP_URL>/reset-parola" to the Redirect URLs allow-list so the
#    password-reset link returns here. Add the platform origin
#    (VITE_RESIDENT_APP_URL's sibling subdomain) to the allow-list too.
#
# Supabase Auth password security (Authentication > Settings > Password Security,
# T32 server-side auth-policy parity -- these settings become the server authority
# so a direct API caller cannot bypass the client-side password policy):
#  - Minimum password length: 10 (matches MIN_POLICY_LENGTH in passwordPolicy.ts)
#  - Password strength: Medium (or higher; requires length + character variety)
#  - "Prohibit use of leaked passwords": ENABLED -- Supabase calls the
#    HaveIBeenPwned (HIBP) k-anonymity API to reject passwords that appear in
#    known breach datasets. Matches the client-side COMMON_PASSWORDS blocklist.
#    Never sends the full password; sends only the first 5 hex chars of the SHA-1
#    hash to the HIBP API (k-anonymity model).
#
# Supabase Auth rate limits (Authentication > Rate Limits, T32):
#  - Sign-up rate limit (per IP per hour): 30 (Supabase default; keep at or below)
#  - Sign-in rate limit (per IP per hour): 30 (Supabase default; keep at or below)
#  - Email rate limit (password reset / magic link per IP per hour): 5 (recommended
#    for production; Supabase default is 60, which is too high for abuse prevention)
#  These server-side limits complement the client-side loginThrottle (5 failures
#  per 15 min per normalised email) without replacing it. The client throttle
#  gives immediate UX feedback; the server limit is the authoritative backstop.

# ============================================================
# Telegram
# ============================================================
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_BOT_USERNAME=your_bot_username
# Random 32+ char string, generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# App configuration
# ============================================================
# Your deployed URL (no trailing slash). APP_URL is read by Netlify functions;
# VITE_APP_URL is read by the client and is used to build the password-reset
# redirect (<VITE_APP_URL>/reset-parola). Defaults to window.location.origin
# when unset.
APP_URL=https://vecini.online
VITE_APP_URL=https://vecini.online

# Base URL of the resident/admin app, used to build onboarding/setup links that
# are minted in the superadmin console (its own subdomain). Set this in the
# platform build so a handed-off link points at the resident origin, not the
# console. Falls back to VITE_APP_URL (then window.location.origin) when unset,
# so the single-origin dev/demo build needs nothing here.
VITE_RESIDENT_APP_URL=https://vecini.online

# URL of the dedicated platform (superadmin) console on its own subdomain (T135).
# When set, the resident/admin app performs a full-page cross-origin redirect here
# whenever a platform superadmin authenticates, so they land on the real console
# rather than the in-app preview. Leave unset for the single-origin dev/demo build.
VITE_PLATFORM_URL=

# Deployment stage: prod (cloud Supabase + Resend), dev (Pi self-hosted Supabase),
# demo (frontend-only offline, no backend). Defaults to prod when Supabase creds
# are present and demo when absent, so existing deploys need not set this.
VITE_APP_STAGE=prod

# Default locale (ro or en)
VITE_DEFAULT_LOCALE=ro

# In-app 2FA enforcement for privileged roles: "strict" (default, production:
# privileged users must set up + pass a second factor before using the app) or
# "relaxed" (self-hosted/dev only; the gate never forces the security page). Any
# value other than "relaxed" resolves to strict. Leave unset for production.
VITE_SECURITY_ENFORCEMENT=strict

# ============================================================
# Optional integrations
# ============================================================
# Sentry for error monitoring (https://sentry.io)
SENTRY_DSN=

# Resend for transactional email (https://resend.com). Required for the live
# invite/onboarding flow (the invite-email + provisioning functions). To deliver
# to arbitrary recipient addresses you MUST verify a sending domain in Resend
# (Domains > Add Domain, then add the DNS records) and set RESEND_FROM_EMAIL to
# an address on that domain. Until a domain is verified, Resend only delivers to
# your own account address. See RUNBOOK-MVP.md.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@vecini.online
# How invite emails are handled by the invite-email Netlify function:
#   resend   (default) - send via the Resend API; requires RESEND_API_KEY
#   log      - write to the email_outbox table + console.info; no external call
#   disabled - silently accept the call; nothing is sent or logged
MAIL_MODE=resend
# Signing secret for the Resend delivery webhook (T149). Obtain after registering
# the endpoint in Resend (Webhooks > Add endpoint -> set to
# <NETLIFY_URL>/.netlify/functions/resend-webhook, select email.delivered +
# email.bounced events). Copy the "Signing Secret" shown on the webhook detail page.
RESEND_WEBHOOK_SECRET=

# Twilio for SMS (only used by F03 alert feature if enabled)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================================
# Development only
# ============================================================
# Set to true to load seed data on first run
DEV_LOAD_SEED=false
