# BlocHub environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# ============================================================
# Supabase
# ============================================================
# Get these from https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Telegram
# ============================================================
# From @BotFather after /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABC...
TELEGRAM_BOT_USERNAME=your_bot_username
# Random 32+ char string, generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# App configuration
# ============================================================
# Your deployed URL (no trailing slash)
APP_URL=https://blochub.netlify.app

# Default locale (ro or en)
VITE_DEFAULT_LOCALE=ro

# ============================================================
# Optional integrations
# ============================================================
# Sentry for error monitoring (https://sentry.io)
SENTRY_DSN=

# Resend for transactional email (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.ro

# Twilio for SMS (only used by F03 alert feature if enabled)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================================
# Development only
# ============================================================
# Set to true to load seed data on first run
DEV_LOAD_SEED=false
