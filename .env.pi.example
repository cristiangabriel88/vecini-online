# IntreVecini - Raspberry Pi / self-hosted environment.
#
# Copy to .env on the Pi and fill in real values. Never commit the real .env.
# All secrets below are REDACTED placeholders. This file mirrors .env.example
# but is tuned for a self-hosted Pi running a minimal local Supabase stack
# (db/auth/rest/kong on 54321/54322) plus the standalone Telegram webhook
# service. See PI_DEPLOYMENT.md for the full walkthrough.

# ============================================================
# Supabase (local stack on the Pi)
# ============================================================
# The Supabase API gateway (kong) listens on 54321 by default. Use the Pi's LAN
# address or hostname so phones/browsers on the network can reach it.
VITE_SUPABASE_URL=http://raspberrypi.local:54321
# Local anon + service-role keys are printed by `supabase start` (or set in
# supabase/config.toml). REDACTED - paste your local keys here.
VITE_SUPABASE_ANON_KEY=REDACTED_LOCAL_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REDACTED_LOCAL_SERVICE_ROLE_KEY

# Direct Postgres connection (used for backups / migrations). The local db
# listens on 54322. REDACTED password.
SUPABASE_DB_URL=postgresql://postgres:REDACTED_DB_PASSWORD@127.0.0.1:54322/postgres

# ============================================================
# Object/file storage
# ============================================================
# Supabase Storage/Studio are excluded on the Pi (they fail health checks), so
# choose how file-backed features behave:
#   supabase - use Supabase Storage (cloud/Netlify default; needs the bucket).
#   local    - a local filesystem adapter serves objects (Pi self-hosting).
#   none     - disable file uploads; storage-backed features show a clear notice.
VITE_STORAGE_MODE=none

# ============================================================
# Telegram (standalone webhook service)
# ============================================================
# From @BotFather after /newbot. REDACTED.
TELEGRAM_BOT_TOKEN=REDACTED_BOT_TOKEN
TELEGRAM_BOT_USERNAME=your_bot_username
# Random 32+ char string: openssl rand -hex 32. Must match the value passed to
# setWebhook. REDACTED.
TELEGRAM_WEBHOOK_SECRET=REDACTED_WEBHOOK_SECRET

# Standalone webhook service (server/telegram-server.ts) bind + route. Keep it
# bound to localhost and put a TLS reverse proxy (Caddy/nginx/Cloudflare Tunnel)
# in front, since Telegram requires HTTPS for setWebhook.
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8787
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# ============================================================
# App configuration
# ============================================================
# Public URL the app is served from (the reverse proxy / tunnel address). Used
# by Netlify functions and to build the password-reset redirect.
APP_URL=https://your-pi-domain.example
VITE_APP_URL=https://your-pi-domain.example

# Default locale (ro or en)
VITE_DEFAULT_LOCALE=ro

# ============================================================
# Optional integrations (REDACTED - leave blank to disable)
# ============================================================
SENTRY_DSN=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.ro
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
