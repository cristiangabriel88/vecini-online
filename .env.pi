# vecini.online - Raspberry Pi / DEV stage committed env.
# Safe placeholder values so `npm run build:pi` works without manual setup.
# Override locally by editing .env.pi directly (or .env.pi.local for secrets).
VITE_APP_STAGE=dev
VITE_DEFAULT_LOCALE=ro
VITE_SECURITY_ENFORCEMENT=relaxed
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=local-anon-key-placeholder
VITE_APP_URL=http://localhost:5173
